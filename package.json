{
  "name": "carecircle",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @carecircle/api run dev",
    "build:api": "npm --workspace @carecircle/api run build",
    "test:api": "npm --workspace @carecircle/api run test:integration"
  }
}
