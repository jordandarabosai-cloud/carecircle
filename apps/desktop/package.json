{
  "name": "@carecircle/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack:mac": "electron-builder --mac --publish never"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "ai.carecircle.desktop",
    "productName": "CareCircle",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.medical"
    }
  }
}
